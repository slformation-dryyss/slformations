# Variables d'Environnement - Production
# A configurer dans la console Clever Cloud

# --- APPLICATION URL (CRITIQUE) ---
# URL de votre application sur Clever Cloud
NEXT_PUBLIC_APP_URL=https://app-17ffc860-acff-4411-8b99-1a5684b8f08d.cleverapps.io

# --- AUTH0 ---
# Secret à générer (commande PowerShell fournie dans le guide)
AUTH0_SECRET=
AUTH0_BASE_URL=https://app-17ffc860-acff-4411-8b99-1a5684b8f08d.cleverapps.io
AUTH0_ISSUER_BASE_URL=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# --- STRIPE ---
# Clés API Stripe (depuis Stripe Dashboard)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# IMPORTANT: Doit être identique à STRIPE_PUBLISHABLE_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Secret du webhook (à ajouter APRES le premier déploiement)
STRIPE_WEBHOOK_SECRET=

# --- EMAILS (RESEND) ---
RESEND_API_KEY=

# --- DATABASE (AUTOMATIQUE) ---
# Ces variables sont injectées automatiquement par Clever Cloud
# NE PAS LES AJOUTER MANUELLEMENT
# DATABASE_URL=
# POSTGRESQL_ADDON_URI=

# --- CONFIGURATION NODE ---
NODE_ENV=production
PORT=8080
